// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core user model
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  firstName String?
  lastName  String?
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    String
  
  // Status: active, suspended, banned
  status    UserStatus @default(ACTIVE)
  
  // Manager relationship - only Agents/Customers have managers
  manager   User?     @relation("ManagerToTeam", fields: [managerId], references: [id])
  managerId String?
  team      User[]    @relation("ManagerToTeam")
  
  // Permissions directly assigned to user
  permissions UserPermission[]
  
  // Customer support tickets
  supportTickets SupportTicket[] @relation("CustomerToTickets")
  assignedTickets SupportTicket[] @relation("AgentToTickets")
  
  // Customer orders
  orders Order[]
  
  // Audit logs
  actionsPerformed AuditLog[] @relation("ActorToAudit")
  
  // JWT refresh tokens for session management
  refreshTokens RefreshToken[]
  
  // API keys if needed in future
  apiKeys   ApiKey[]
  
  // Leads created/assigned
  leadsCreated Lead[] @relation("LeadCreatedBy")
  leadsAssigned Lead[] @relation("LeadAssignedTo")
  
  // Tasks created/assigned
  tasksCreated Task[] @relation("TaskCreatedBy")
  tasksAssigned Task[] @relation("TaskAssignee")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
  @@index([managerId])
  @@index([status])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

// Core role model
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  
  // Role hierarchy level for grant ceiling enforcement
  level       Int      // 0 = Customer, 1 = Agent, 2 = Manager, 3 = Admin
  
  // Default permissions for this role
  permissions RolePermission[]
  
  // Users with this role
  users       User[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Permission atom - fine-grained access units
model Permission {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  category     String   // e.g., "dashboard", "users", "leads", "reports", "audit", "settings"
  resourceType String?  // e.g., "page", "action", "module"
  
  // Which roles have this permission by default
  roles        RolePermission[]
  
  // Which users have been explicitly granted/denied this
  users        UserPermission[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// Join table: Role -> Permissions (default permissions)
model RolePermission {
  id           String   @id @default(cuid())
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String
  
  createdAt    DateTime @default(now())

  @@unique([roleId, permissionId])
}

// Join table: User -> Permissions (override at user level)
// granted = true means user has this permission (override default)
// granted = false means user is denied this permission (revoke from default)
model UserPermission {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String
  
  // true = granted, false = explicitly denied
  granted      Boolean  @default(true)
  
  grantedBy    String?  // user who granted/denied this
  reason       String?  // why was this granted/denied
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([granted])
}

// Audit log - append-only record of all admin/manager actions
model AuditLog {
  id          String   @id @default(cuid())
  actor       User     @relation("ActorToAudit", fields: [actorId], references: [id])
  actorId     String
  
  action      String   // e.g., "CREATE_USER", "GRANT_PERMISSION", "SUSPEND_USER"
  resourceType String  // e.g., "USER", "PERMISSION", "ROLE"
  resourceId  String   // ID of the resource being acted upon
  
  changes     Json?    // Before/after values
  reason      String?
  
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
}

// Refresh token tracking for logout/session management
model RefreshToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  
  token     String   @unique
  
  // When it expires
  expiresAt DateTime
  
  // When it was revoked (null = still valid)
  revokedAt DateTime?
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

// API Keys for future integrations
model ApiKey {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  
  key       String   @unique
  name      String?
  
  revokedAt DateTime?
  expiresAt DateTime?
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([key])
}

// Support Ticket model for customer portal
model SupportTicket {
  id            String   @id @default(cuid())
  ticketNumber  String   @unique
  
  customer      User     @relation("CustomerToTickets", fields: [customerId], references: [id], onDelete: Cascade)
  customerId    String
  
  assignedAgent User?    @relation("AgentToTickets", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  assignedAgentId String?
  
  title         String
  description   String
  status        TicketStatus @default(OPEN)
  priority      TicketPriority @default(NORMAL)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([priority])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Order model for customer portal
model Order {
  id            String   @id @default(cuid())
  orderNumber   String   @unique
  
  customer      User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId    String
  
  productName   String
  quantity      Int
  total         Float
  status        OrderStatus @default(PENDING)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// Lead model for sales/customer acquisition
model Lead {
  id            String   @id @default(cuid())
  name          String?
  email         String
  phone         String?
  company       String?
  contact       String?
  status        String   @default("New")
  source        String?
  notes         String?
  value         Float?
  
  createdBy     User?    @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById   String?
  
  assignedTo    User?    @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToId  String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdById])
  @@index([assignedToId])
}

// Task model for project/work management
model Task {
  id            String   @id @default(cuid())
  title         String
  description   String?
  status        String   @default("Pending")
  priority      TaskPriority @default(MEDIUM)
  dueDate       DateTime?
  
  createdBy     User?    @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById   String?
  
  assignee      User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId    String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([createdById])
  @@index([assigneeId])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
